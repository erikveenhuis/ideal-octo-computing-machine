[MAIN]
# Use multiple processes to speed up Pylint
jobs=1

# Allow loading of arbitrary C extensions
unsafe-load-any-extension=no

# Trust runtime introspection for these C-extension modules so the
# c-extension-no-member info messages stop firing for symbols pylint's
# static analysis can't see (notably lxml.etree.QName).
extension-pkg-allow-list=lxml,lxml.etree,pymupdf

[MESSAGES CONTROL]
# Disable specific warnings that are too strict for this codebase
disable=
    # Imports — kept disabled
    import-error,
    import-outside-toplevel,
    
    # Code structure
    too-few-public-methods,
    too-many-arguments,
    too-many-positional-arguments,
    too-many-locals,
    too-many-return-statements,
    
    # Exception handling
    broad-exception-caught,
    
    # Formatting (handled by other tools)
    line-too-long,
    trailing-whitespace,
    missing-final-newline,
    
    # Logging
    logging-fstring-interpolation,
    
    # Code duplication (acceptable for services)
    duplicate-code,
    
    # Miscellaneous
    protected-access

[FORMAT]
# Maximum number of characters on a single line
max-line-length=100

# Maximum number of lines in a module.
#
# Bumped from 1000 to 1100 to accommodate ``services/pdf_export_service.py``
# (~1050 lines). The file is intentionally kept as a single module
# because the test suite imports many of its private helpers
# (``_parse_svg``, ``_split_thrucut``, ``_set_spot_color_recursive``,
# ``_set_white_spot_recursive``, ``_set_page_trimbox_mm``, ``_mm_to_pt``,
# ``THRUCUT_SPOT_CMYK``, ``WHITE_SPOT_CMYK`` …) and splitting it would
# require either a wrapper-package re-export layer that obscures the
# call graph or a coordinated test-suite rewrite. The module is thoroughly
# documented at the section level (parser, splitter, painters, renderer,
# merger, trimbox writer) so the lack of file boundaries does not impede
# navigation. Revisit if the file grows past 1300 lines.
max-module-lines=1100

[DESIGN]
# Maximum number of arguments for function / method
max-args=7

# Maximum number of locals for function / method body
max-locals=20

# Maximum number of return / yield for function / method body
max-returns=8

# Maximum number of branch for function / method body
max-branches=15

# Maximum number of statements in function / method body
max-statements=50

# Maximum number of parents for a class (see R0901)
max-parents=7

# Maximum number of attributes for a class (see R0902)
max-attributes=10

# Minimum number of public methods for a class (see R0903)
min-public-methods=1

# Maximum number of public methods for a class (see R0904)
max-public-methods=20

[SIMILARITIES]
# Minimum lines number of a similarity
min-similarity-lines=6

# Ignore comments when computing similarities
ignore-comments=yes

# Ignore docstrings when computing similarities
ignore-docstrings=yes

# Ignore imports when computing similarities
ignore-imports=yes

[BASIC]
# Good variable names which should always be accepted.
# - i,j,k,e,f,n  : standard loop / exception / file / node abbreviations
# - x0..y2       : coordinate pairs in geometry helpers
# - tx,ty,vw,vh,
#   pw,ph,rx,ry,
#   rw,rh,vb,mm  : math-style names used heavily in the SVG / PDF
#                  geometry pipeline; renaming them to ``page_width``
#                  hurts readability of the formulas
# - c            : canvas (matches the reportlab idiom ``c = canvas.Canvas(...)``)
# - cg           : cut group (used inside the SVG splitter)
# - l,b,r,t      : left / bottom / right / top, a common box quadruple
# - id,db,app    : Flask / SQLAlchemy idioms
good-names=i,j,k,n,e,f,_,_e,ex,Run,pr,id,db,app,
           x0,y0,x1,y1,x2,y2,
           tx,ty,vw,vh,pw,ph,rx,ry,rw,rh,vb,mm,
           w,h,c,cg,l,b,r,t

# Regular expression matching correct function names
function-rgx=[a-z_][a-z0-9_]{2,50}$

# Regular expression matching correct variable names
variable-rgx=[a-z_][a-z0-9_]{2,30}$

# Regular expression matching correct constant names
const-rgx=(([A-Z_][A-Z0-9_]*)|(__.*__))$

# Regular expression matching correct attribute names
attr-rgx=[a-z_][a-z0-9_]{2,30}$

# Regular expression matching correct argument names
argument-rgx=[a-z_][a-z0-9_]{2,30}$

# Regular expression matching correct class attribute names
class-attribute-rgx=([A-Za-z_][A-Za-z0-9_]{2,30}|(__.*__))$

# Regular expression matching correct inline iteration names
inlinevar-rgx=[A-Za-z_][A-Za-z0-9_]*$

# Regular expression matching correct class names
class-rgx=[A-Z_][a-zA-Z0-9]+$

# Regular expression matching correct module names
module-rgx=(([a-z_][a-z0-9_]*)|([A-Z][a-zA-Z0-9]+))$

# Regular expression matching correct method names
method-rgx=[a-z_][a-z0-9_]{2,50}$

[TYPECHECK]
# List of module names for which member attributes should not be checked
ignored-modules=

# List of class names for which member attributes should not be checked
ignored-classes=

[REPORTS]
# Set the output format
output-format=text

# Tells whether to display a full report or only the messages
reports=no

# Template used to display messages
msg-template={path}:{line}: [{msg_id}({symbol}), {obj}] {msg}

[LOGGING]
# Format style used to check logging format string
logging-format-style=new 