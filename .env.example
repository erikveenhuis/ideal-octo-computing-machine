# ---------------------------------------------------------------------------
# Local development environment variables.
#
# Copy this file to ``.env`` and fill in real values. Flask reads ``.env``
# automatically via python-dotenv at app boot
# (see ``config.py``::``load_dotenv()``). ``.env`` itself is gitignored;
# this committed example is the documented contract.
#
# Variables in ALL_CAPS_WITH_UNDERSCORES are read by ``Config`` /
# ``ProductionConfig`` / ``TestingConfig`` in ``config.py``. Required
# columns below mirror the table in README.md.
# ---------------------------------------------------------------------------

# REQUIRED in production. Strong random string used to sign Flask sessions
# and CSRF tokens. ProductionConfig.validate() refuses to boot if this is
# unset or still equal to the dev fallback. Any local dev value is fine.
SECRET_KEY=change-me-locally

# REQUIRED for the route map (``/``). Mapbox GL JS token used by the viewer.
# Public tokens (pk.*) are fine.
MAPBOX_ACCESS_TOKEN=pk.your-mapbox-token

# REQUIRED for /webhook. HMAC secret used to verify GitHub push webhooks.
# Use the same string here as in the GitHub webhook configuration.
GITHUB_WEBHOOK_SECRET=replace-with-shared-secret

# Flask config selector. One of ``development`` (default), ``production``,
# ``testing``. ``testing`` disables CSRF and rate limits in tests.
# On PythonAnywhere, set ``production`` here or in the WSGI file so
# ProductionConfig (WSGI touch path, rate limits) matches the live site.
FLASK_CONFIG=development

# Optional. Local dev server bind address. Defaults to 127.0.0.1:8000.
HOST=127.0.0.1
PORT=8000

# Optional. Logging level: DEBUG, INFO, WARNING, ERROR. Defaults to INFO
# (DEBUG in DevelopmentConfig).
LOG_LEVEL=INFO

# Optional. Rate-limiter storage backend. Defaults to in-process memory;
# point at a redis URL in production for cross-worker accuracy.
# REDIS_URL=redis://localhost:6379/0

# Optional. Used by the GitHub webhook deployment service in production.
# Leave unset locally — the dev server has no business touching the
# WSGI file or the venv pip.
# WSGI_FILE_PATH=/var/www/yourdomain_com_wsgi.py
# VENV_PIP_PATH=/home/you/.virtualenvs/your-app/bin/pip
